# Auto-detect text files and normalize line endings
* text=auto

# Clojure
*.clj text diff=clojure
*.cljs text diff=clojure
*.cljc text diff=clojure
*.edn text

# OpenCL kernels
*.c text

# Documentation
*.md text

# Binary files — do not diff
*.pdf binary
*.jar binary

# Lock files
*.lock text

# Shell scripts
*.sh text eol=lf
